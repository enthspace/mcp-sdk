{
    "name": "@enth/mcp-sdk",
    "version": "1.19.1",
    "description": "Model Context Protocol implementation for TypeScript",
    "license": "MIT",
    "author": "Anthropic, PBC (https://anthropic.com)",
    "homepage": "https://modelcontextprotocol.io",
    "bugs": "https://github.com/modelcontextprotocol/typescript-sdk/issues",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/modelcontextprotocol/typescript-sdk.git"
    },
    "engines": {
        "node": ">=18"
    },
    "keywords": [
        "modelcontextprotocol",
        "mcp"
    ],
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        },
        "./client": {
            "import": "./dist/esm/client/index.js",
            "require": "./dist/cjs/client/index.js"
        },
        "./server": {
            "import": "./dist/esm/server/index.js",
            "require": "./dist/cjs/server/index.js"
        },
        "./*": {
            "import": "./dist/esm/*",
            "require": "./dist/cjs/*"
        }
    },
    "typesVersions": {
        "*": {
            "*": [
                "./dist/esm/*"
            ]
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "fetch:spec-types": "curl -o spec.types.ts https://raw.githubusercontent.com/modelcontextprotocol/modelcontextprotocol/refs/heads/main/schema/draft/schema.ts",
        "build": "tsc -b tsconfig.prod.json && tsdown",
        "examples:simple-server:w": "tsx --watch src/examples/server/simpleStreamableHttp.ts --oauth",
        "prepack": "npm run build",
        "lint": "eslint src/ && prettier --check .",
        "size-limit": "size-limit",
        "size-limit:why": "size-limit --why --save-bundle .temp --clean-dir",
        "test": "npm run fetch:spec-types && vitest run",
        "start": "npm run server",
        "server": "tsx watch --clear-screen=false src/cli.ts server",
        "client": "tsx src/cli.ts client"
    },
    "dependencies": {
        "@enth/mcp-specs": "^1.0.0-beta.28",
        "content-type": "^1.0.5",
        "cors": "^2.8.5",
        "cross-spawn": "^7.0.5",
        "eventsource": "^3.0.2",
        "eventsource-parser": "^3.0.0",
        "express": "^5.0.1",
        "express-rate-limit": "^7.5.0",
        "pkce-challenge": "^5.0.0",
        "raw-body": "^3.0.0"
    },
    "peerDependencies": {
        "@cfworker/json-schema": "^4.1.1",
        "@valibot/to-json-schema": "^1.3.0",
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1",
        "typebox": "^1.0.20",
        "valibot": "^1.1.0",
        "zod": "^4.1.11"
    },
    "peerDependenciesMeta": {
        "@cfworker/json-schema": {
            "optional": true
        },
        "@valibot/to-json-schema": {
            "optional": true
        },
        "ajv": {
            "optional": true
        },
        "ajv-formats": {
            "optional": true
        },
        "typebox": {
            "optional": true
        },
        "valibot": {
            "optional": true
        },
        "zod": {
            "optional": true
        }
    },
    "devDependencies": {
        "@cfworker/json-schema": "^4.1.1",
        "@eslint/js": "^9.8.0",
        "@size-limit/esbuild-why": "^11.2.0",
        "@size-limit/preset-small-lib": "^11.2.0",
        "@types/content-type": "^1.1.8",
        "@types/cors": "^2.8.17",
        "@types/cross-spawn": "^6.0.6",
        "@types/eslint__js": "^8.42.3",
        "@types/eventsource": "^1.1.15",
        "@types/express": "^5.0.0",
        "@types/node": "^22.0.2",
        "@types/supertest": "^6.0.2",
        "@types/ws": "^8.5.12",
        "@valibot/to-json-schema": "^1.3.0",
        "@vitest/coverage-v8": "^3.2.4",
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1",
        "eslint": "^9.8.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "3.6.2",
        "size-limit": "^11.2.0",
        "supertest": "^7.0.0",
        "tsdown": "^0.15.5",
        "tsx": "^4.16.5",
        "typebox": "^1.0.27",
        "typescript": "^5.5.4",
        "typescript-eslint": "^8.0.0",
        "valibot": "^1.1.0",
        "vitest": "^3.2.4",
        "ws": "^8.18.0",
        "zod": "^4.1.12"
    },
    "resolutions": {
        "strip-ansi": "6.0.1"
    }
}
